{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "resources": [
    {%- for item in azure.network_security_groups %}
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-05-01",
      "name": "{{ item }}",
      "location": "{{ azure.network_security_groups[item].properties.location }}",
      "properties": {
        "securityRules": []
      },
      "tags": {{ azure.network_security_groups[item].properties.tags | default({}) | to_json }}
    }{% if not loop.last %},{% endif %}

    {%- endfor %}
  ]
}
